{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "Default": "Server=cloudgame-sqlserver,1433;Database=CloudGamePaymentsDB;User Id=sa;Password=CloudGame#2026;TrustServerCertificate=True;Connect Timeout=30;"
  },
  "RabbitMQ": {
    "Host": "cloudgame-rabbitmq",
    "Port": "5672",
    "Username": "admin",
    "Password": "admin123"
  },
  "PaymentProcessing": {
    "ApprovalPercentage": 80,
    "DefaultPaymentType": "CreditCard"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {SourceContext} - {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
